MONGODB_URI=
JWT_SECRET=
ADMIN_SECRET_KEY=
NODE_ENV=development

# URL pública de la app (links en emails de invitación)
APP_URL=http://localhost:3000

# SendGrid — correos transaccionales e invitaciones
# 1. Crea API Key en SendGrid → Settings → API Keys (permiso Mail Send)
# 2. Verifica remitente → Settings → Sender Authentication → Single Sender
# 3. El email verificado debe coincidir EXACTAMENTE con SENDGRID_FROM_EMAIL
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=GymPro

# Cloudinary — imágenes (ejercicios, comidas, productos, logo del gym)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
